# Copie este arquivo para ".env" nesta mesma pasta, no servidor, e preencha os valores.
# O arquivo ".env" real NUNCA deve ir para o GitHub (já está no .gitignore).

# --- Domínio ---
# Subdomínio apontando (registro DNS tipo A) para o IP do servidor.
EVOLUTION_DOMAIN=evolution.barbeariadoju.com.br

# --- Postgres interno da Evolution API (não é o banco da barbearia) ---
POSTGRES_DB=evolution
POSTGRES_USER=evolution
POSTGRES_PASSWORD=GERAR_UMA_SENHA_ALEATORIA

# --- Evolution API ---
SERVER_URL=https://evolution.barbeariadoju.com.br
AUTHENTICATION_API_KEY=GERAR_UMA_CHAVE_ALEATORIA
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true

DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:GERAR_UMA_SENHA_ALEATORIA@postgres:5432/evolution?schema=evolution_api
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true

CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/6
CACHE_LOCAL_ENABLED=false

# O webhook é configurado por instância (via chamada de API), não aqui.
WEBHOOK_GLOBAL_ENABLED=false
WEBHOOK_GLOBAL_URL=
